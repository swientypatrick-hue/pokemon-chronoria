---
import Layout from "../../../layouts/Layout.astro";
import TypeBadge from "../../../components/TypeBadge.astro";
import StatBar from "../../../components/StatBar.astro";
import EnBadge from "../../../components/EnBadge.astro";
import { pokemon, pokemonById, moveById, abilityById, itemById, slugify, pokemonDexNumber } from "../../../lib/data";
import { formatEvolutionCondition } from "../../../lib/evolutionMethods";
import { encounterMethodLabel } from "../../../lib/encounterMethods";
import { eggGroupLabel } from "../../../lib/eggGroups";
import { href } from "../../../lib/url";

export function getStaticPaths() {
  return pokemon.map((p) => ({ params: { pokemonId: slugify(p.id) }, props: { p } }));
}

const { p } = Astro.props;

const statTotal =
  p.baseStats.hp + p.baseStats.attack + p.baseStats.defense +
  p.baseStats.speed + p.baseStats.spAtk + p.baseStats.spDef;

function moveName(id: string) {
  return moveById.get(id)?.name ?? id;
}
function abilityName(id: string) {
  return abilityById.get(id)?.name ?? id;
}
function speciesName(id: string) {
  return pokemonById.get(id)?.name ?? id;
}
function itemName(id: string) {
  return itemById.get(id)?.name;
}

const megaFormsFromHere = p.forms.filter((mf: any) => mf.megaStone && mf.unmegaForm === 0);

const sortedLevelMoves = [...p.levelMoves].sort((a, b) => a.level - b.level);
const sortedTutorMoves = [...p.tutorMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const sortedEggMoves = [...p.eggMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const locationsByPlace = Object.groupBy
  ? Object.groupBy(p.foundIn, (r: any) => r.locationName)
  : p.foundIn.reduce((acc: Record<string, any[]>, r: any) => {
      (acc[r.locationName] ??= []).push(r);
      return acc;
    }, {});
---

<Layout title={p.name}>
  <p class="meta-note"><a href={href("/pokemon/")}>← Alle Pokémon</a></p>
  <h1><span class="dex-number">#{String(pokemonDexNumber.get(p.id)).padStart(3, "0")}</span> {p.name}</h1>
  {p.sprite && (
    <div class="species-sprite-frame">
      <img class="species-sprite" src={href(`/sprites/${p.sprite}`)} alt={p.name} width="288" height="288" />
    </div>
  )}
  <div class="pill-list">
    {p.types.map((t: string) => <TypeBadge type={t} />)}
  </div>

  <h2>Basiswerte</h2>
  <StatBar label="LP" value={p.baseStats.hp} />
  <StatBar label="Angriff" value={p.baseStats.attack} />
  <StatBar label="Verteidigung" value={p.baseStats.defense} />
  <StatBar label="Sp. Angriff" value={p.baseStats.spAtk} />
  <StatBar label="Sp. Vert." value={p.baseStats.spDef} />
  <StatBar label="Init." value={p.baseStats.speed} />
  <div class="stat-row">
    <span class="stat-label">Gesamt</span>
    <span></span>
    <span class="stat-value">{statTotal}</span>
  </div>

  <h2>Pokédex</h2>
  <p>
    {p.pokedex.text || "–"}
    {p.pokedex.fallback && p.pokedex.text && <EnBadge />}
  </p>
  <table>
    <tr><th>Größe</th><td>{p.height} m</td></tr>
    <tr><th>Gewicht</th><td>{p.weight} kg</td></tr>
    <tr><th>Fangrate</th><td>{p.catchRate}</td></tr>
    <tr><th>Ei-Gruppen</th><td>{p.eggGroups.map(eggGroupLabel).join(", ") || "–"}</td></tr>
    <tr><th>Schlüpfschritte</th><td>{p.hatchSteps}</td></tr>
    {p.raidRanks.length > 0 && (
      <tr><th>Raid-Rang</th><td>{Math.min(...p.raidRanks)}{p.raidRanks.length > 1 ? `–${Math.max(...p.raidRanks)}` : ""} ⭐</td></tr>
    )}
  </table>

  <h2>Fähigkeiten</h2>
  <div class="pill-list">
    {p.abilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)}</a>)}
    {p.hiddenAbilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)} (versteckt)</a>)}
  </div>

  <h2>Entwicklung</h2>
  {p.evolvesFrom && (
    <p>Entwickelt sich aus <a href={href(`/pokemon/${slugify(p.evolvesFrom)}/`)}>{speciesName(p.evolvesFrom)}</a>.</p>
  )}
  {p.evolutions.length > 0 && (
    <ul>
      {p.evolutions.map((evo: any) => (
        <li>
          <a href={href(`/pokemon/${slugify(evo.target)}/`)}>{speciesName(evo.target)}</a>
          {" — "}{formatEvolutionCondition(evo.method, evo.param, itemName)}
        </li>
      ))}
    </ul>
  )}
  {megaFormsFromHere.length > 0 && (
    <ul>
      {megaFormsFromHere.map((mf: any) => (
        <li>
          Kann mega-entwickeln zu{" "}
          <a href={href(`/pokemon/${slugify(p.id)}/${mf.formNumber}/`)}>{mf.formName?.text || `Form ${mf.formNumber}`}</a>
        </li>
      ))}
    </ul>
  )}
  {p.evolutions.length === 0 && megaFormsFromHere.length === 0 && !p.evolvesFrom && (
    <p class="section-empty">Entwickelt sich nicht weiter.</p>
  )}

  {p.forms.length > 0 && (
    <>
      <h2>Formen</h2>
      <table>
        <tr><th></th><th>Form</th><th>Typ(en)</th><th>Basiswerte</th></tr>
        {p.forms.map((f: any) => (
          <tr>
            <td><a href={href(`/pokemon/${slugify(p.id)}/${f.formNumber}/`)}>{f.sprite && <img class="form-sprite" src={href(`/sprites/${f.sprite}`)} alt="" width="40" height="40" />}</a></td>
            <td><a href={href(`/pokemon/${slugify(p.id)}/${f.formNumber}/`)}>{f.formName?.text || `Form ${f.formNumber}`}</a></td>
            <td><div class="pill-list">{f.types.map((t: string) => <TypeBadge type={t} />)}</div></td>
            <td>
              <div class="form-stat-grid">
                <span class="form-stat"><span class="form-stat-lbl">LP</span><span class="form-stat-val">{f.baseStats.hp}</span></span>
                <span class="form-stat"><span class="form-stat-lbl">Ang</span><span class="form-stat-val">{f.baseStats.attack}</span></span>
                <span class="form-stat"><span class="form-stat-lbl">Vert</span><span class="form-stat-val">{f.baseStats.defense}</span></span>
                <span class="form-stat"><span class="form-stat-lbl">SpA</span><span class="form-stat-val">{f.baseStats.spAtk}</span></span>
                <span class="form-stat"><span class="form-stat-lbl">SpV</span><span class="form-stat-val">{f.baseStats.spDef}</span></span>
                <span class="form-stat"><span class="form-stat-lbl">Init</span><span class="form-stat-val">{f.baseStats.speed}</span></span>
              </div>
            </td>
          </tr>
        ))}
      </table>
    </>
  )}

  <h2>Attacken (durch Levelaufstieg)</h2>
  {sortedLevelMoves.length > 0 ? (
    <table>
      <tr><th>Level</th><th>Attacke</th><th>Typ</th><th>AP</th><th>Stärke</th><th>Genauigkeit</th></tr>
      {sortedLevelMoves.map((lm: any) => {
        const mv = moveById.get(lm.move);
        return (
          <tr>
            <td>{lm.level === 0 ? "bei Entwicklung" : lm.level}</td>
            <td><a href={href(`/attacken/${slugify(lm.move)}/`)}>{moveName(lm.move)}</a></td>
            <td>{mv && <TypeBadge type={mv.type} />}</td>
            <td>{mv?.totalPP ?? "–"}</td>
            <td>{mv?.power ?? "–"}</td>
            <td>{mv?.accuracy ?? "–"}</td>
          </tr>
        );
      })}
    </table>
  ) : <p class="section-empty">Keine Level-Attacken bekannt.</p>}

  {p.tutorMoves.length > 0 && (
    <>
      <h2>Tutor-Attacken</h2>
      <div class="pill-list">
        {sortedTutorMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  {p.eggMoves.length > 0 && (
    <>
      <h2>Ei-Attacken</h2>
      <div class="pill-list">
        {sortedEggMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  <h2>Fundorte (wild)</h2>
  {Object.keys(locationsByPlace).length > 0 ? (
    <table>
      <tr><th>Ort</th><th>Methode</th><th>Level</th></tr>
      {Object.entries(locationsByPlace).map(([place, refs]: [string, any]) => (
        refs.map((r: any, i: number) => (
          <tr>
            {i === 0 ? <td rowspan={refs.length}>{place}</td> : null}
            <td>{encounterMethodLabel(r.method)}</td>
            <td>{r.minLevel === r.maxLevel ? r.minLevel : `${r.minLevel}–${r.maxLevel}`}</td>
          </tr>
        ))
      ))}
    </table>
  ) : <p class="section-empty">Kein bekannter wilder Fundort (z.B. nur durch Entwicklung, Geschenk oder Ei erhältlich).</p>}
</Layout>
