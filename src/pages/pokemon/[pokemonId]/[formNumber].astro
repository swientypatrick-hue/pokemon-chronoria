---
import Layout from "../../../layouts/Layout.astro";
import TypeBadge from "../../../components/TypeBadge.astro";
import StatBar from "../../../components/StatBar.astro";
import { pokemon, pokemonById, moveById, abilityById, itemById, slugify, pokemonDexNumber } from "../../../lib/data";
import { encounterMethodLabel } from "../../../lib/encounterMethods";
import { formatEvolutionCondition } from "../../../lib/evolutionMethods";
import { href } from "../../../lib/url";

export function getStaticPaths() {
  return pokemon.flatMap((p) =>
    p.forms.map((f) => ({
      params: { pokemonId: slugify(p.id), formNumber: String(f.formNumber) },
      props: { p, f },
    }))
  );
}

const { p, f } = Astro.props;

function moveName(id: string) {
  return moveById.get(id)?.name ?? id;
}
function abilityName(id: string) {
  return abilityById.get(id)?.name ?? id;
}
function speciesName(id: string) {
  return pokemonById.get(id)?.name ?? id;
}
function itemName(id: string) {
  return itemById.get(id)?.name;
}
/** If the evolution target has a form with the same form number, this form line evolves into
 *  that specific form (e.g. Onix "Kristall" form 1 -> Steelix "Kristall" form 1) rather than
 *  the target's base form. */
function evoTarget(targetId: string, formNumber: number) {
  const targetForm = pokemonById.get(targetId)?.forms.find((tf: any) => tf.formNumber === formNumber);
  if (targetForm) {
    return {
      url: href(`/pokemon/${slugify(targetId)}/${formNumber}/`),
      label: `${speciesName(targetId)} (${targetForm.formName?.text || `Form ${formNumber}`})`,
    };
  }
  return { url: href(`/pokemon/${slugify(targetId)}/`), label: speciesName(targetId) };
}

const formLabel = f.formName?.text || `Form ${f.formNumber}`;
const sortedLevelMoves = [...f.levelMoves].sort((a: any, b: any) => a.level - b.level);
const sortedTutorMoves = [...f.tutorMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const sortedEggMoves = [...f.eggMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const statTotal =
  f.baseStats.hp + f.baseStats.attack + f.baseStats.defense +
  f.baseStats.speed + f.baseStats.spAtk + f.baseStats.spDef;
const locationsByPlace = Object.groupBy
  ? Object.groupBy(f.foundIn, (r: any) => r.locationName)
  : f.foundIn.reduce((acc: Record<string, any[]>, r: any) => {
      (acc[r.locationName] ??= []).push(r);
      return acc;
    }, {});
---

<Layout title={`${p.name} (${formLabel})`}>
  <p class="meta-note"><a href={href(`/pokemon/${slugify(p.id)}/`)}>← {p.name}</a></p>
  <h1><span class="dex-number">#{String(pokemonDexNumber.get(p.id)).padStart(3, "0")}</span> {p.name} <span class="meta-note">— {formLabel}</span></h1>
  {f.sprite && (
    <div class="species-sprite-frame">
      <img class="species-sprite" src={href(`/sprites/${f.sprite}`)} alt={`${p.name} (${formLabel})`} width="288" height="288" />
    </div>
  )}
  <div class="pill-list">
    {f.types.map((t: string) => <TypeBadge type={t} />)}
  </div>
  <p class="meta-note">
    Diese Form von <a href={href(`/pokemon/${slugify(p.id)}/`)}>{p.name}</a> ändert Typ(en), Basiswerte,
    Fähigkeiten und Attacken - Pokédex-Eintrag siehe Basisform.
  </p>

  <h2>Basiswerte</h2>
  <StatBar label="LP" value={f.baseStats.hp} />
  <StatBar label="Angriff" value={f.baseStats.attack} />
  <StatBar label="Verteidigung" value={f.baseStats.defense} />
  <StatBar label="Sp. Angriff" value={f.baseStats.spAtk} />
  <StatBar label="Sp. Vert." value={f.baseStats.spDef} />
  <StatBar label="Init." value={f.baseStats.speed} />
  <div class="stat-row">
    <span class="stat-label">Gesamt</span>
    <span></span>
    <span class="stat-value">{statTotal}</span>
  </div>

  <h2>Fähigkeiten</h2>
  <div class="pill-list">
    {f.abilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)}</a>)}
    {f.hiddenAbilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)} (versteckt)</a>)}
  </div>

  <h2>Entwicklung</h2>
  {p.evolvesFrom && (
    <p>Entwickelt sich aus <a href={href(`/pokemon/${slugify(p.evolvesFrom)}/`)}>{speciesName(p.evolvesFrom)}</a>.</p>
  )}
  {f.evolutions.length > 0 ? (
    <ul>
      {f.evolutions.map((evo: any) => {
        const target = evoTarget(evo.target, f.formNumber);
        return (
          <li>
            <a href={target.url}>{target.label}</a>
            {" — "}{formatEvolutionCondition(evo.method, evo.param, itemName)}
          </li>
        );
      })}
    </ul>
  ) : (
    !p.evolvesFrom && <p class="section-empty">Entwickelt sich nicht weiter.</p>
  )}

  <h2>Attacken (durch Levelaufstieg)</h2>
  {sortedLevelMoves.length > 0 ? (
    <table>
      <tr><th>Level</th><th>Attacke</th><th>Typ</th><th>AP</th><th>Stärke</th><th>Genauigkeit</th></tr>
      {sortedLevelMoves.map((lm: any) => {
        const mv = moveById.get(lm.move);
        return (
          <tr>
            <td>{lm.level === 0 ? "bei Entwicklung" : lm.level}</td>
            <td><a href={href(`/attacken/${slugify(lm.move)}/`)}>{moveName(lm.move)}</a></td>
            <td>{mv && <TypeBadge type={mv.type} />}</td>
            <td>{mv?.totalPP ?? "–"}</td>
            <td>{mv?.power ?? "–"}</td>
            <td>{mv?.accuracy ?? "–"}</td>
          </tr>
        );
      })}
    </table>
  ) : <p class="section-empty">Keine Level-Attacken bekannt.</p>}

  {f.tutorMoves.length > 0 && (
    <>
      <h2>Tutor-Attacken</h2>
      <div class="pill-list">
        {sortedTutorMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  {f.eggMoves.length > 0 && (
    <>
      <h2>Ei-Attacken</h2>
      <div class="pill-list">
        {sortedEggMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  <h2>Fundorte (wild)</h2>
  {Object.keys(locationsByPlace).length > 0 ? (
    <table>
      <tr><th>Ort</th><th>Methode</th><th>Level</th></tr>
      {Object.entries(locationsByPlace).map(([place, refs]: [string, any]) => (
        refs.map((r: any, i: number) => (
          <tr>
            {i === 0 ? <td rowspan={refs.length}>{place}</td> : null}
            <td>{encounterMethodLabel(r.method)}</td>
            <td>{r.minLevel === r.maxLevel ? r.minLevel : `${r.minLevel}–${r.maxLevel}`}</td>
          </tr>
        ))
      ))}
    </table>
  ) : <p class="section-empty">Kein bekannter wilder Fundort für diese Form.</p>}
</Layout>
