---
import Layout from "../../../layouts/Layout.astro";
import TypeBadge from "../../../components/TypeBadge.astro";
import StatBar from "../../../components/StatBar.astro";
import { pokemon, pokemonById, moveById, abilityById, itemById, slugify, pokemonDexNumber, typeNameById } from "../../../lib/data";
import { encounterMethodLabel } from "../../../lib/encounterMethods";
import { formatEvolutionCondition } from "../../../lib/evolutionMethods";
import { eggGroupLabel } from "../../../lib/eggGroups";
import { wildItemRows } from "../../../lib/wildItems";
import { href } from "../../../lib/url";

export function getStaticPaths() {
  return pokemon.flatMap((p) =>
    p.forms.map((f) => ({
      params: { pokemonId: slugify(p.id), formNumber: String(f.formNumber) },
      props: { p, f },
    }))
  );
}

const { p, f } = Astro.props;

function moveName(id: string) {
  return moveById.get(id)?.name ?? id;
}
function abilityName(id: string) {
  return abilityById.get(id)?.name ?? id;
}
function speciesName(id: string) {
  return pokemonById.get(id)?.name ?? id;
}
function itemName(id: string) {
  return itemById.get(id)?.name;
}
function typeName(id: string) {
  return typeNameById.get(id);
}
/** Link to a species page, or to one specific form of it if formNumber > 0 and that form
 *  exists (e.g. Onix "Kristall" form 1 evolves into Steelix "Kristall" form 1, not Steelix's
 *  base form; a Mega form's UnmegaForm may likewise point at a non-base form to revert to). */
function pokemonFormLink(speciesId: string, formNumber: number) {
  if (formNumber > 0) {
    const targetForm = pokemonById.get(speciesId)?.forms.find((tf: any) => tf.formNumber === formNumber);
    if (targetForm) {
      return {
        url: href(`/pokemon/${slugify(speciesId)}/${formNumber}/`),
        label: `${speciesName(speciesId)} (${targetForm.formName?.text || `Form ${formNumber}`})`,
      };
    }
  }
  return { url: href(`/pokemon/${slugify(speciesId)}/`), label: speciesName(speciesId) };
}

const evolvesFromLink = p.evolvesFrom ? pokemonFormLink(p.evolvesFrom, f.formNumber) : null;
const unmegaLink = f.megaStone ? pokemonFormLink(p.id, f.unmegaForm) : null;
/** Forms of this same species that Mega Evolve FROM this form (UnmegaForm points back at it) -
 *  the reverse of unmegaLink above, shown as a forward "can Mega Evolve into" relationship. */
const megaFormsFromHere = p.forms.filter((mf: any) => mf.megaStone && mf.unmegaForm === f.formNumber);
const wildItems = wildItemRows(f.wildItemCommon, f.wildItemUncommon, f.wildItemRare);

const formLabel = f.formName?.text || `Form ${f.formNumber}`;
const sortedLevelMoves = [...f.levelMoves].sort((a: any, b: any) => a.level - b.level);
const sortedTutorMoves = [...f.tutorMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const sortedEggMoves = [...f.eggMoves].sort((a, b) => moveName(a).localeCompare(moveName(b), "de"));
const statTotal =
  f.baseStats.hp + f.baseStats.attack + f.baseStats.defense +
  f.baseStats.speed + f.baseStats.spAtk + f.baseStats.spDef;
const locationsByPlace = Object.groupBy
  ? Object.groupBy(f.foundIn, (r: any) => r.locationName)
  : f.foundIn.reduce((acc: Record<string, any[]>, r: any) => {
      (acc[r.locationName] ??= []).push(r);
      return acc;
    }, {});
---

<Layout title={`${p.name} (${formLabel})`}>
  <div class="detail-hero">
    <p class="meta-note"><a href={href(`/pokemon/${slugify(p.id)}/`)}>← {p.name}</a></p>
    <h1><span class="dex-number">#{String(pokemonDexNumber.get(p.id)).padStart(3, "0")}</span> {p.name} <span class="meta-note">— {formLabel}</span></h1>
    {(f.sprite || f.femaleSprite) && (
      <div class="sprite-pair">
        {f.sprite && (
          <figure>
            <div class="species-sprite-frame">
              <img class="species-sprite" src={href(`/sprites/${f.sprite}`)} alt={`${p.name} (${formLabel})`} width="288" height="288" />
            </div>
            {f.femaleSprite && <figcaption>♂ Männlich</figcaption>}
          </figure>
        )}
        {f.femaleSprite && (
          <figure>
            <div class="species-sprite-frame">
              <img class="species-sprite" src={href(`/sprites/${f.femaleSprite}`)} alt={`${p.name} (${formLabel}, weiblich)`} width="288" height="288" />
            </div>
            <figcaption>♀ Weiblich</figcaption>
          </figure>
        )}
      </div>
    )}
    <div class="pill-list">
      {f.types.map((t: string) => <TypeBadge type={t} />)}
    </div>
    {f.shinySprite && (
      <p class="meta-note"><a href={href(`/shiny/${slugify(p.id)}/${f.formNumber}/`)}>✨ Shiny-Version ansehen</a></p>
    )}
  </div>

  <h2>Basiswerte</h2>
  <StatBar label="LP" value={f.baseStats.hp} />
  <StatBar label="Angriff" value={f.baseStats.attack} />
  <StatBar label="Verteidigung" value={f.baseStats.defense} />
  <StatBar label="Sp. Angriff" value={f.baseStats.spAtk} />
  <StatBar label="Sp. Vert." value={f.baseStats.spDef} />
  <StatBar label="Init." value={f.baseStats.speed} />
  <div class="stat-row">
    <span class="stat-label">Gesamt</span>
    <span></span>
    <span class="stat-value">{statTotal}</span>
  </div>

  <h2>Pokédex</h2>
  <p>
    {f.pokedex.text || "–"}
  </p>
  <table>
    <tr><th>Größe</th><td>{f.height} m</td></tr>
    <tr><th>Gewicht</th><td>{f.weight} kg</td></tr>
    <tr><th class="help-text" title="Je höher der Wert, desto leichter lässt sich das Pokémon fangen (0–255).">Fangrate</th><td>{f.catchRate}</td></tr>
    <tr><th>Ei-Gruppen</th><td>{f.eggGroups.map(eggGroupLabel).join(", ") || "–"}</td></tr>
    <tr><th>Schlüpfschritte</th><td>{f.hatchSteps}</td></tr>
    {f.raidRanks.length > 0 && (
      <tr><th>Raid-Rang</th><td>{Math.min(...f.raidRanks)}{f.raidRanks.length > 1 ? `–${Math.max(...f.raidRanks)}` : ""} ⭐</td></tr>
    )}
  </table>

  <h2>Fähigkeiten</h2>
  <div class="pill-list">
    {f.abilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)}</a>)}
    {f.hiddenAbilities.map((a: string) => <a class="card" href={href(`/faehigkeiten/${slugify(a)}/`)}>{abilityName(a)} (versteckt)</a>)}
  </div>

  <h2>Entwicklung</h2>
  {unmegaLink ? (
    <p>Dies ist die Mega-Form von <a href={unmegaLink.url}>{unmegaLink.label}</a>.</p>
  ) : (
    evolvesFromLink && <p>Entwickelt sich aus <a href={evolvesFromLink.url}>{evolvesFromLink.label}</a>.</p>
  )}
  {f.evolutions.length > 0 && (
    <ul>
      {f.evolutions.map((evo: any) => {
        const target = pokemonFormLink(evo.target, f.formNumber);
        return (
          <li>
            <a href={target.url}>{target.label}</a>
            {" — "}{formatEvolutionCondition(evo.method, evo.param, itemName, moveName, typeName, speciesName)}
          </li>
        );
      })}
    </ul>
  )}
  {megaFormsFromHere.length > 0 && (
    <ul>
      {megaFormsFromHere.map((mf: any) => (
        <li>
          Kann mega-entwickeln zu{" "}
          <a href={href(`/pokemon/${slugify(p.id)}/${mf.formNumber}/`)}>{mf.formName?.text || `Form ${mf.formNumber}`}</a>
        </li>
      ))}
    </ul>
  )}
  {f.evolutions.length === 0 && megaFormsFromHere.length === 0 && !evolvesFromLink && !unmegaLink && (
    <p class="section-empty">Entwickelt sich nicht weiter.</p>
  )}

  <h2>Attacken (durch Levelaufstieg)</h2>
  {sortedLevelMoves.length > 0 ? (
    <table>
      <tr><th>Level</th><th>Attacke</th><th>Typ</th><th>AP</th><th>Stärke</th><th>Genauigkeit</th></tr>
      {sortedLevelMoves.map((lm: any) => {
        const mv = moveById.get(lm.move);
        return (
          <tr>
            <td>{lm.level === 0 ? "bei Entwicklung" : lm.level}</td>
            <td><a href={href(`/attacken/${slugify(lm.move)}/`)}>{moveName(lm.move)}</a></td>
            <td>{mv && <TypeBadge type={mv.type} />}</td>
            <td>{mv?.totalPP ?? "–"}</td>
            <td>{mv?.power ?? "–"}</td>
            <td>{mv?.accuracy ?? "–"}</td>
          </tr>
        );
      })}
    </table>
  ) : <p class="section-empty">Keine Level-Attacken bekannt.</p>}

  {f.tutorMoves.length > 0 && (
    <>
      <h2>Tutor-Attacken</h2>
      <div class="pill-list">
        {sortedTutorMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  {f.eggMoves.length > 0 && (
    <>
      <h2>Ei-Attacken</h2>
      <div class="pill-list">
        {sortedEggMoves.map((m: string) => <a class="card" href={href(`/attacken/${slugify(m)}/`)}>{moveName(m)}</a>)}
      </div>
    </>
  )}

  {wildItems.length > 0 && (
    <>
      <h2>Mögliche Item-Funde (wild)</h2>
      <ul>
        {wildItems.map((row) => (
          <li>
            {row.chance}:{" "}
            {row.itemIds.map((id: string, i: number) => (
              <>
                {i > 0 && ", "}
                <a href={href(`/items/${slugify(id)}/`)}>{itemName(id) ?? id}</a>
              </>
            ))}
          </li>
        ))}
      </ul>
    </>
  )}

  <h2>Fundorte (wild)</h2>
  {Object.keys(locationsByPlace).length > 0 ? (
    <table>
      <tr><th>Ort</th><th>Methode</th><th>Level</th></tr>
      {Object.entries(locationsByPlace).map(([place, refs]: [string, any]) => (
        refs.map((r: any, i: number) => (
          <tr>
            {i === 0 ? <td rowspan={refs.length}>{place}</td> : null}
            <td>{encounterMethodLabel(r.method)}</td>
            <td>{r.minLevel === r.maxLevel ? r.minLevel : `${r.minLevel}–${r.maxLevel}`}</td>
          </tr>
        ))
      ))}
    </table>
  ) : <p class="section-empty">Kein bekannter wilder Fundort für diese Form.</p>}
</Layout>
