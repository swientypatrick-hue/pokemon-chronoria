---
import Layout from "../../layouts/Layout.astro";
import TypeBadge from "../../components/TypeBadge.astro";
import { pokemon, types, pokemonDexNumber } from "../../lib/data";
import { slugify } from "../../lib/data";
import { href } from "../../lib/url";
import { typeColor } from "../../lib/typeColors";
---

<Layout title="Pokémon">
  <h1>Pokémon ({pokemon.length})</h1>

  <input
    type="search"
    id="name-search"
    class="text-input"
    placeholder="Nach Namen suchen…"
    aria-label="Pokémon nach Namen durchsuchen"
  />

  <div class="filter-bar" id="type-filter">
    <a href="#" data-type="ALL" aria-current="true">Alle</a>
    {types.filter((t) => t.id !== "QMARKS").map((t) => (
      <a href="#" data-type={t.id}>{t.name}</a>
    ))}
  </div>

  <p class="meta-note" id="result-count"></p>

  <div class="card-grid" id="pokemon-grid">
    {pokemon.map((p) => (
      <a
        class="card"
        href={href(`/pokemon/${slugify(p.id)}/`)}
        data-types={p.types.join(",")}
        data-name={p.name.toLowerCase()}
        style={`--card-glow:${typeColor(p.types[0])}66`}
      >
        {p.sprite && <img class="card-sprite" src={href(`/sprites/${p.sprite}`)} alt="" loading="lazy" width="64" height="64" />}
        <div class="card-id">#{String(pokemonDexNumber.get(p.id)).padStart(3, "0")}</div>
        <div class="card-name">{p.name}</div>
        <div class="pill-list" style="margin-top:0.35rem">
          {p.types.map((t) => <TypeBadge type={t} />)}
        </div>
      </a>
    ))}
  </div>
</Layout>

<script>
  const filterBar = document.getElementById("type-filter")!;
  const nameSearch = document.getElementById("name-search") as HTMLInputElement;
  const resultCount = document.getElementById("result-count")!;
  const grid = document.getElementById("pokemon-grid")!;
  const cards = [...grid.querySelectorAll<HTMLElement>("[data-types]")];

  let activeType = "ALL";

  function applyFilters() {
    const query = nameSearch.value.trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const cardTypes = card.dataset.types?.split(",") ?? [];
      const matchesType = activeType === "ALL" || cardTypes.includes(activeType);
      const matchesName = query === "" || (card.dataset.name ?? "").includes(query);
      const show = matchesType && matchesName;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    }
    resultCount.textContent = query || activeType !== "ALL" ? `${visible} Treffer` : "";
  }

  filterBar.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest("a[data-type]");
    if (!link) return;
    e.preventDefault();
    activeType = link.getAttribute("data-type")!;

    for (const a of filterBar.querySelectorAll("a")) a.removeAttribute("aria-current");
    link.setAttribute("aria-current", "true");
    applyFilters();
  });

  nameSearch.addEventListener("input", applyFilters);
</script>
