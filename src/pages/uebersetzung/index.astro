---
import Layout from "../../layouts/Layout.astro";
import FallbackList from "../../components/FallbackList.astro";
import { pokemon, moves, abilities, items, meta, slugify } from "../../lib/data";
import { href } from "../../lib/url";

const sortByLabel = <T extends { label: string }>(list: T[]) => list.sort((a, b) => a.label.localeCompare(b.label, "de"));

const pokemonNameTodo = sortByLabel(
  pokemon.filter((p) => p.nameFallback).map((p) => ({ href: href(`/pokemon/${slugify(p.id)}/`), label: p.name }))
);
const pokedexTodo = sortByLabel(
  pokemon.filter((p) => p.pokedex.fallback && p.pokedex.text).map((p) => ({ href: href(`/pokemon/${slugify(p.id)}/`), label: p.name }))
);
const categoryTodo = sortByLabel(
  pokemon.filter((p) => p.category.fallback && p.category.text).map((p) => ({ href: href(`/pokemon/${slugify(p.id)}/`), label: `${p.name} („${p.category.text}“)` }))
);
const moveNameTodo = sortByLabel(
  moves.filter((m) => m.nameFallback).map((m) => ({ href: href(`/attacken/${slugify(m.id)}/`), label: m.name }))
);
const moveDescriptionTodo = sortByLabel(
  moves.filter((m) => m.description.fallback && m.description.text).map((m) => ({ href: href(`/attacken/${slugify(m.id)}/`), label: m.name }))
);
const abilityNameTodo = sortByLabel(
  abilities.filter((a) => a.nameFallback).map((a) => ({ href: href(`/faehigkeiten/${slugify(a.id)}/`), label: a.name }))
);
const itemNameTodo = sortByLabel(
  items.filter((i) => i.nameFallback).map((i) => ({ href: href(`/items/${slugify(i.id)}/`), label: i.name }))
);

const totalTodo =
  pokemonNameTodo.length + pokedexTodo.length + categoryTodo.length +
  moveNameTodo.length + moveDescriptionTodo.length + abilityNameTodo.length + itemNameTodo.length;
---

<Layout title="Übersetzungsstatus">
  <h1>Übersetzungsstatus</h1>
  <p>
    Diese Seite listet alles, was im Spiel noch keine deutsche Übersetzung hat und deshalb auf der
    Wiki mit einem <span class="badge badge-en" style="margin:0 0.2rem">EN</span>-Hinweis den
    englischen Text zeigt. Jede Liste ist zum Aufklappen - ein Klick auf einen Eintrag führt direkt
    zur jeweiligen Seite.
  </p>

  <div class="card-grid">
    <div class="stat-tile">
      <div class="stat-tile-value">{totalTodo}</div>
      <div class="stat-tile-label">Insgesamt offen</div>
    </div>
    <div class="stat-tile">
      <div class="stat-tile-value">{meta.counts.pokemon}</div>
      <div class="stat-tile-label">Pokémon gesamt</div>
    </div>
    <div class="stat-tile">
      <div class="stat-tile-value">{meta.counts.moves}</div>
      <div class="stat-tile-label">Attacken gesamt</div>
    </div>
    <div class="stat-tile">
      <div class="stat-tile-value">{meta.counts.items}</div>
      <div class="stat-tile-label">Items gesamt</div>
    </div>
  </div>

  <h2>Pokémon</h2>
  <FallbackList title="Namen" items={pokemonNameTodo} />
  <FallbackList title="Pokédex-Einträge" items={pokedexTodo} />
  <FallbackList title="Kategorien (z.B. „Seed Pokémon“)" items={categoryTodo} />

  <h2>Attacken</h2>
  <FallbackList title="Namen" items={moveNameTodo} />
  <FallbackList title="Beschreibungen" items={moveDescriptionTodo} />

  <h2>Fähigkeiten</h2>
  <FallbackList title="Namen" items={abilityNameTodo} />

  <h2>Items</h2>
  <FallbackList title="Namen" items={itemNameTodo} />

  {totalTodo === 0 && <p class="section-empty">Alles übersetzt! 🎉</p>}
</Layout>
