---
import Layout from "../../layouts/Layout.astro";
import { items, slugify } from "../../lib/data";
import { pocketName } from "../../lib/itemPockets";
import { href } from "../../lib/url";

export function getStaticPaths() {
  return items.map((i) => ({ params: { itemId: slugify(i.id) }, props: { i } }));
}

const { i } = Astro.props;
---

<Layout title={i.name}>
  <p class="meta-note"><a href={href("/items/")}>← Alle Items</a></p>
  <h1>{i.name}</h1>
  {i.icon && <img class="species-sprite" src={href(`/item-icons/${i.icon}`)} alt="" width="64" height="64" />}
  <p>{i.description || "–"}</p>

  <table>
    <tr><th>Preis</th><td>{i.price !== null ? `${i.price} ₽` : "nicht käuflich"}</td></tr>
    <tr><th>Tasche</th><td>{pocketName(i.pocket)}</td></tr>
  </table>
</Layout>
