---
import Layout from "../layouts/Layout.astro";
import { meta, pokemon, medals } from "../lib/data";
import { href } from "../lib/url";

const formsCount = pokemon.reduce((sum, p) => sum + p.forms.filter((f) => !f.isFemaleForm).length, 0);
const shinyCount = pokemon.filter((p) => p.shinySprite).length;

const categories = [
  { href: href("/pokemon/"), label: "Pokémon", count: meta.counts.pokemon },
  { href: href("/formen/"), label: "Formen", count: formsCount },
  { href: href("/shiny/"), label: "Shiny", count: shinyCount },
  { href: href("/attacken/"), label: "Attacken", count: meta.counts.moves },
  { href: href("/faehigkeiten/"), label: "Fähigkeiten", count: meta.counts.abilities },
  { href: href("/items/"), label: "Items", count: meta.counts.items },
  { href: href("/trainer/"), label: "Trainer", count: meta.counts.trainers },
  { href: href("/medaillen/"), label: "Medaillen", count: medals.length },
];
---

<Layout title="Start">
  <section class="hero">
    <h1>Chronoria-Wiki</h1>
    <p>Alles zu Pokémon, Attacken, Fähigkeiten, Items und Trainern aus unserem Spiel.</p>
    <div class="hero-search" id="search"></div>
  </section>

  <div class="card-grid">
    {categories.map((c) => (
      <a class="card" href={c.href}>
        <div class="card-name">{c.label}</div>
        <div class="meta-note">{c.count}</div>
      </a>
    ))}
  </div>

  <p class="meta-note" style="margin-top:2rem">
    Stand: {new Date(meta.generatedAt).toLocaleDateString("de-DE")} · Work in Progress — Ideen und Feedback sind jederzeit willkommen.
  </p>
</Layout>

<link rel="stylesheet" href={href("/pagefind/pagefind-ui.css")} />
<script is:inline src={href("/pagefind/pagefind-ui.js")}></script>
<script is:inline define:vars={{ bundlePath: href("/pagefind/") }}>
  window.addEventListener("DOMContentLoaded", () => {
    if (typeof PagefindUI !== "undefined") {
      new PagefindUI({ element: "#search", bundlePath, showSubResults: true, resetStyles: false });
    }
  });
</script>
