---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { meta, pokemon, medals } from "../lib/data";
import { href } from "../lib/url";

const formsCount = pokemon.reduce((sum, p) => sum + p.forms.filter((f) => !f.isFemaleForm).length, 0);
const shinyCount = pokemon.filter((p) => p.shinySprite).length;

const categories = [
  { href: href("/pokemon/"), label: "Pokémon", count: meta.counts.pokemon },
  { href: href("/formen/"), label: "Formen", count: formsCount },
  { href: href("/shiny/"), label: "Shiny", count: shinyCount },
  { href: href("/attacken/"), label: "Attacken", count: meta.counts.moves },
  { href: href("/faehigkeiten/"), label: "Fähigkeiten", count: meta.counts.abilities },
  { href: href("/items/"), label: "Items", count: meta.counts.items },
  { href: href("/trainer/"), label: "Trainer", count: meta.counts.trainers },
  { href: href("/medaillen/"), label: "Medaillen", count: medals.length },
];

// Built here (instead of via define:vars) because is:inline + define:vars makes Astro rebuild
// the <script> tag during compilation, which silently drops the data-astro-rerun attribute added
// below - define:vars needs this re-run too (see the script tag's own comment for why).
const pagefindInitScript = `if (typeof PagefindUI !== "undefined") {
  new PagefindUI({ element: "#search", bundlePath: ${JSON.stringify(href("/pagefind/"))}, showSubResults: true, resetStyles: false });
}`;
---

<Layout title="Start">
  <section class="hero">
    <h1>Chronoria-Wiki</h1>
    <p>Die zentrale Wissensdatenbank für Pokémon Chronoria. Entdecke detaillierte Informationen zu Pokémon, Formen, Shinys, Attacken, Fähigkeiten, Items, Trainern und Medaillen – schnell, übersichtlich und stets griffbereit.</p>
    <div class="hero-search" id="search"></div>
  </section>

  <div class="card-grid">
    {categories.map((c) => (
      <Card href={c.href}>
        <div class="card-name">{c.label}</div>
        <div class="meta-note">{c.count}</div>
      </Card>
    ))}
  </div>

  <p class="meta-note" style="margin-top:2rem">
    Stand: {new Date(meta.generatedAt).toLocaleDateString("de-DE")} · Work in Progress — Ideen und Feedback sind jederzeit willkommen.
  </p>
</Layout>

<link rel="stylesheet" href={href("/pagefind/pagefind-ui.css")} />
<script is:inline src={href("/pagefind/pagefind-ui.js")}></script>
{/* data-astro-rerun so this re-runs every time the homepage is reached via a ClientRouter
    navigation, not just the very first load - without it the #search box built by PagefindUI
    stayed empty after navigating back to "/" (DOMContentLoaded, which the old version waited
    for, only ever fires once per real document load, never again for client-side navigations).
    No need to wait for any event here: by the time an inline script tag runs (first load or
    rerun-reinsertion alike), the preceding #search element is already in the document. */}
<script is:inline data-astro-rerun set:html={pagefindInitScript} />
