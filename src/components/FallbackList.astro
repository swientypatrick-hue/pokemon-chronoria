---
interface Item {
  href: string;
  label: string;
}
interface Props {
  title: string;
  items: Item[];
}
const { title, items } = Astro.props;
---

{items.length > 0 && (
  <details class="fallback-list">
    <summary>{title} ({items.length})</summary>
    <div class="pill-list">
      {items.map((i) => <a class="card" href={i.href}>{i.label}</a>)}
    </div>
  </details>
)}
