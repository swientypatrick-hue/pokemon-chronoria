---
import "../styles/global.css";
import { href } from "../lib/url";

interface Props {
  title: string;
}
const { title } = Astro.props;
const nav = [
  { href: href("/"), label: "Start" },
  { href: href("/pokemon/"), label: "Pokémon" },
  { href: href("/attacken/"), label: "Attacken" },
  { href: href("/faehigkeiten/"), label: "Fähigkeiten" },
  { href: href("/items/"), label: "Items" },
  { href: href("/trainer/"), label: "Trainer" },
];
const currentPath = Astro.url.pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={href("/favicon.svg")} />
    <title>{title} · Pokémon-Wiki</title>
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="page">
        <a class="site-title" href={href("/")}>Pokémon-Wiki</a>
        <nav class="site-nav" aria-label="Hauptnavigation">
          {nav.map((item) => (
            <a href={item.href} aria-current={(currentPath.startsWith(item.href) && item.href !== href("/")) || currentPath === item.href ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="page">
      <slot />
    </main>

    <script>
      // Scroll-reveal: fade+lift each top-level section of the page as it enters the
      // viewport. Applied generically here (not per-page) so every page gets it for free.
      // Skips the <h1> so the page title is visible immediately on load.
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReducedMotion) {
        const targets = document.querySelectorAll("main.page > :not(h1)");
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08, rootMargin: "0px 0px -10% 0px" }
        );
        targets.forEach((el, i) => {
          el.classList.add("reveal");
          (el as HTMLElement).style.transitionDelay = `${Math.min(i, 6) * 40}ms`;
          io.observe(el);
        });
      }
    </script>
  </body>
</html>
