---
import "../styles/global.css";
import { href } from "../lib/url";

interface Props {
  title: string;
}
const { title } = Astro.props;
const nav = [
  { href: href("/"), label: "Start" },
  { href: href("/pokemon/"), label: "Pokémon" },
  { href: href("/formen/"), label: "Formen" },
  { href: href("/attacken/"), label: "Attacken" },
  { href: href("/faehigkeiten/"), label: "Fähigkeiten" },
  { href: href("/items/"), label: "Items" },
  { href: href("/trainer/"), label: "Trainer" },
];
const currentPath = Astro.url.pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={href("/favicon.svg")} />
    <title>{title} · Pokémon-Wiki</title>
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="page">
        <a class="site-title" href={href("/")}>Pokémon-Wiki</a>
        <nav class="site-nav" aria-label="Hauptnavigation">
          {nav.map((item) => (
            <a href={item.href} aria-current={(currentPath.startsWith(item.href) && item.href !== href("/")) || currentPath === item.href ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="page">
      <slot />
    </main>

    <script>
      // Scroll-reveal: fade+lift each top-level section of the page as it enters the
      // viewport. Applied generically here (not per-page) so every page gets it for free.
      // Skips the <h1> so the page title is visible immediately on load.
      //
      // threshold must stay 0 (not e.g. 0.08): threshold is a fraction of the TARGET's own
      // area, not "any part visible" - some pages have a single huge target (e.g. the 1082-item
      // grid, far taller than the viewport), and that fraction can never be reached, so the
      // element stayed opacity:0 forever. threshold:0 fires as soon as even one pixel is in view.
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReducedMotion) {
        const targets = document.querySelectorAll("main.page > :not(h1)");
        const reveal = (el: Element) => el.classList.add("is-visible");
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                reveal(entry.target);
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0 }
        );
        targets.forEach((el, i) => {
          el.classList.add("reveal");
          (el as HTMLElement).style.transitionDelay = `${Math.min(i, 6) * 40}ms`;
          io.observe(el);
        });
        // Safety net: never let content stay permanently invisible if the observer somehow
        // misses an element - force-reveal everything after a short delay regardless.
        setTimeout(() => targets.forEach(reveal), 1500);
      }
    </script>

    <script>
      // Auto-hide header: slide it up out of view when scrolling down, bring it back when
      // scrolling up (or near the top). Runs on every page via this shared layout.
      const header = document.querySelector<HTMLElement>(".site-header")!;
      let lastY = window.scrollY;
      let ticking = false;
      const HIDE_AFTER_PX = 80; // don't hide while still near the top of the page

      function onScroll() {
        const y = window.scrollY;
        if (y > lastY && y > HIDE_AFTER_PX) {
          header.classList.add("site-header--hidden");
        } else if (y < lastY) {
          header.classList.remove("site-header--hidden");
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(onScroll);
          ticking = true;
        }
      });
    </script>
  </body>
</html>
